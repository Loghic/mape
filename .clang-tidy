# clang-tidy configuration for the C++ pricing core + FFI.
#
# Philosophy: clang-tidy should catch *bugs*, not enforce one house style. We
# enable the analyzer, the bug-prone family, performance, and the
# correctness-oriented core-guidelines checks, then disable the purely
# stylistic ones (brace placement, designated initializers, [[nodiscard]]
# placement, redundant parentheses on well-understood math, etc.) that would
# otherwise produce hundreds of no-value diffs and fight the codebase's
# deliberate, consistent style.
#
# Notable disables and why:
#   * performance-enum-size — OptionType/Exercise/BarrierKind are mirrored
#     across the C ABI as C enums (int) and as #[repr(i32)] in Rust. Shrinking
#     the C++ base type would create a cross-language ABI size mismatch, far
#     worse than the few bytes saved. The check is wrong for this architecture.
#   * pro-bounds-* / pro-type-vararg — the FFI layer is intentionally C-style
#     (pointers, printf-free but raw arrays across the boundary).
#   * avoid-magic-numbers — financial formulas are full of literal constants.
#
# NOTE: do NOT put comments inside the `Checks:` folded scalar below — YAML
# folds them into the string and breaks parsing of the lines that follow.
Checks: >
  clang-analyzer-*,
  bugprone-*,
  performance-*,
  cppcoreguidelines-*,
  modernize-use-override,
  modernize-use-nullptr,
  modernize-use-using,
  modernize-loop-convert,
  modernize-make-unique,
  modernize-make-shared,
  -bugprone-easily-swappable-parameters,
  -performance-enum-size,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-avoid-do-while,
  -cppcoreguidelines-owning-memory,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-avoid-unchecked-container-access,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-narrowing-conversions,
  -cppcoreguidelines-use-default-member-init,
  -cppcoreguidelines-special-member-functions,
  -cppcoreguidelines-avoid-non-const-global-variables,
  -cppcoreguidelines-macro-usage,
  -cppcoreguidelines-init-variables

WarningsAsErrors: ''
HeaderFilterRegex: 'core/include/mape/.*'
FormatStyle: none
